{
  "name": "recess",
  "version": "0.1.0",
  "private": true,
  "description": "童年游戏合集 - Childhood Game Collection",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
